# OpenAI compatible chat completion config.
# Copy this file to .env and replace values with your own.

OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini

# Server and local storage.
PORT=8080
AGENT_DB_PATH=agent.db

# Web search provider config.
# Leave WEB_SEARCH_PROVIDER=none to disable web.search.
# Set WEB_SEARCH_PROVIDER=serper and SERPER_API_KEY to enable Serper.dev search.
WEB_SEARCH_PROVIDER=serper
SERPER_API_KEY=your-serper-api-key
SERPER_SEARCH_URL=https://google.serper.dev/search
